#!/usr/bin/env bash

# ======================================
# detect_dup - JavaScript重複コード検出ツール
# ======================================
# シンプルで動作する最小版

set -o pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# カラー定義（先に定義）
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

# 共通ライブラリ読み込み
if [ -f "$SCRIPT_DIR/../lib/common.sh" ]; then
    source "$SCRIPT_DIR/../lib/common.sh"
fi

VERSION="1.0.0"

# デフォルト設定
DEFAULT_WINDOW=5
OUTPUT_FORMAT="console"
DETECTION_TYPE="all"
TARGET_DIR=""
WINDOW_SIZE=$DEFAULT_WINDOW

# 一時ディレクトリ
TMP_DIR=$(mktemp -d)
trap "rm -rf $TMP_DIR" EXIT

# ハッシュコマンド検出
if command -v md5sum &> /dev/null; then
    HASH_CMD="md5sum"
elif command -v md5 &> /dev/null; then
    HASH_CMD="md5 -q"
else
    echo "Error: md5sum or md5 command not found"
    exit 1
fi

# ======================================
# ヘルプ表示
# ======================================
show_help() {
    cat << EOF
${BOLD}${CYAN}detect_dup${RESET} - JavaScript 重複コード検出ツール v${VERSION}

${BOLD}使用方法:${RESET}
    detect_dup [OPTIONS] <target-directory> [window-size]

${BOLD}オプション:${RESET}
    ${GREEN}-h, --help${RESET}              このヘルプを表示
    ${GREEN}-v, --version${RESET}           バージョン情報を表示
    ${GREEN}-a, --all${RESET}               全検出を実行（デフォルト）
    ${GREEN}-b, --basic${RESET}             基本的な重複のみ検出
    ${GREEN}-t, --text${RESET}              テキストレベル重複のみ
    ${GREEN}-o, --output <format>${RESET}   出力形式 (console/json/csv)

${BOLD}引数:${RESET}
    target-directory    スキャン対象ディレクトリ
    window-size         ウィンドウサイズ（行数、デフォルト: 5）

${BOLD}検出タイプ:${RESET}
    ${CYAN}BASIC${RESET}       - 完全一致する重複コードブロック
    ${CYAN}TEXT${RESET}        - テキストレベルの類似コード
    ${CYAN}MULTILINE${RESET}   - 複数行にわたる重複

${BOLD}使用例:${RESET}
    # 基本的な使用
    detect_dup ./src

    # ウィンドウサイズ指定
    detect_dup ./src 10

    # JSON出力
    detect_dup --output json ./project

    # 基本検出のみ
    detect_dup --basic ./src

${BOLD}出力例:${RESET}
    ${RED}[BASIC_W5]${RESET} Hash: a1b2c3d4
      src/user.js:10
      src/admin.js:25

EOF
}

# ======================================
# 基本的な重複検出
# ======================================
detect_basic() {
    local target="$1"
    local window="$2"
    
    echo "[INFO] 基本的な重複検出を実行中 (ウィンドウサイズ: $window)" >&2
    
    # JavaScriptファイルを検索
    find "$target" -name "*.js" -type f \
        ! -path "*/node_modules/*" \
        ! -path "*/dist/*" \
        ! -path "*/build/*" \
        ! -path "*/.git/*" | while read -r file; do
        
        # ファイルを読み込み、ウィンドウサイズ分のブロックを作成
        awk -v ws="$window" '
        {
            lines[NR] = $0
        }
        END {
            for (i = 1; i <= NR - ws + 1; i++) {
                block = ""
                for (j = i; j < i + ws; j++) {
                    block = block lines[j] "\n"
                }
                # 空白行のみのブロックをスキップ
                if (block !~ /^[[:space:]]*$/) {
                    print i ":" block
                }
            }
        }
        ' "$file" | while IFS=: read -r line_num block; do
            # ブロックをハッシュ化
            hash=$(echo "$block" | $HASH_CMD | awk '{print $1}')
            echo "$hash	$file:$line_num"
        done
    done > "$TMP_DIR/basic_hashes.txt"
    
    # 重複を検出
    if [ -s "$TMP_DIR/basic_hashes.txt" ]; then
        sort "$TMP_DIR/basic_hashes.txt" | awk '
        {
            hash = $1
            location = $2
            if (hash in locations) {
                locations[hash] = locations[hash] "," location
                counts[hash]++
            } else {
                locations[hash] = location
                counts[hash] = 1
            }
        }
        END {
            for (hash in locations) {
                if (counts[hash] > 1) {
                    print hash "\t" locations[hash]
                }
            }
        }
        ' | while IFS=$'\t' read -r hash locs; do
            output_result "BASIC_W${window}" "$hash" "$locs"
        done
    fi
}

# ======================================
# テキストレベル重複検出
# ======================================
detect_text() {
    local target="$1"
    local window="$2"
    
    echo "[INFO] テキストレベル重複検出を実行中" >&2
    
    # 文字列リテラルの重複を検出
    find "$target" -name "*.js" -type f \
        ! -path "*/node_modules/*" \
        ! -path "*/dist/*" | while read -r file; do
        
        grep -n '"[^"]\{20,\}"' "$file" 2>/dev/null | while IFS=: read -r line_num content; do
            # 文字列を抽出
            string=$(echo "$content" | grep -o '"[^"]*"' | head -1)
            if [ -n "$string" ]; then
                hash=$(echo "$string" | $HASH_CMD | awk '{print $1}')
                echo "$hash	$file:$line_num	$string"
            fi
        done
    done > "$TMP_DIR/text_hashes.txt"
    
    # 重複を検出
    if [ -s "$TMP_DIR/text_hashes.txt" ]; then
        sort "$TMP_DIR/text_hashes.txt" | awk -F'\t' '
        {
            hash = $1
            location = $2
            if (hash in locations) {
                locations[hash] = locations[hash] "," location
                counts[hash]++
            } else {
                locations[hash] = location
                counts[hash] = 1
            }
        }
        END {
            for (hash in locations) {
                if (counts[hash] > 1) {
                    print hash "\t" locations[hash]
                }
            }
        }
        ' | while IFS=$'\t' read -r hash locs; do
            output_result "TEXT_STRING" "$hash" "$locs"
        done
    fi
}

# ======================================
# 結果出力
# ======================================
output_result() {
    local type="$1"
    local hash="$2"
    local locations="$3"
    
    case "$OUTPUT_FORMAT" in
        json)
            # JSON形式
            echo "  {"
            echo "    \"type\": \"$type\","
            echo "    \"hash\": \"$hash\","
            echo "    \"locations\": ["
            local first=true
            IFS=',' read -ra LOCS <<< "$locations"
            for loc in "${LOCS[@]}"; do
                if [ "$first" = true ]; then
                    first=false
                else
                    echo ","
                fi
                echo -n "      \"$loc\""
            done
            echo ""
            echo "    ]"
            echo "  }"
            ;;
        csv)
            # CSV形式
            echo "\"$type\",\"$hash\",\"$locations\""
            ;;
        console|*)
            # コンソール形式
            echo -e "${RED}[$type]${RESET} Hash: ${BOLD}${hash:0:8}${RESET}"
            IFS=',' read -ra LOCS <<< "$locations"
            for loc in "${LOCS[@]}"; do
                echo -e "  ${GREEN}$loc${RESET}"
            done
            echo ""
            ;;
    esac
}

# ======================================
# メイン処理
# ======================================
main() {
    if [ $# -eq 0 ]; then
        show_help
        exit 0
    fi
    
    # 引数解析
    while [ $# -gt 0 ]; do
        case "$1" in
            -h|--help)
                show_help
                exit 0
                ;;
            -v|--version)
                echo "detect_dup v$VERSION"
                exit 0
                ;;
            -a|--all)
                DETECTION_TYPE="all"
                shift
                ;;
            -b|--basic)
                DETECTION_TYPE="basic"
                shift
                ;;
            -t|--text)
                DETECTION_TYPE="text"
                shift
                ;;
            -o|--output)
                OUTPUT_FORMAT="$2"
                shift 2
                ;;
            -*)
                echo "Error: Unknown option: $1" >&2
                echo "Use --help for usage information" >&2
                exit 1
                ;;
            *)
                if [ -z "$TARGET_DIR" ]; then
                    TARGET_DIR="$1"
                elif [ -z "$WINDOW_SIZE" ] || [ "$WINDOW_SIZE" = "$DEFAULT_WINDOW" ]; then
                    WINDOW_SIZE="$1"
                fi
                shift
                ;;
        esac
    done
    
    # ターゲットディレクトリ必須チェック
    if [ -z "$TARGET_DIR" ]; then
        echo "Error: Target directory is required" >&2
        echo "Use --help for usage information" >&2
        exit 1
    fi
    
    if [ ! -d "$TARGET_DIR" ]; then
        echo "Error: Directory not found: $TARGET_DIR" >&2
        exit 1
    fi
    
    # JSON/CSVヘッダー
    if [ "$OUTPUT_FORMAT" = "json" ]; then
        echo "{"
        echo "  \"tool\": \"detect_dup\","
        echo "  \"version\": \"$VERSION\","
        echo "  \"target\": \"$TARGET_DIR\","
        echo "  \"window_size\": $WINDOW_SIZE,"
        echo "  \"duplicates\": ["
    elif [ "$OUTPUT_FORMAT" = "csv" ]; then
        echo "type,hash,locations"
    fi
    
    # 検出実行
    case "$DETECTION_TYPE" in
        basic)
            detect_basic "$TARGET_DIR" "$WINDOW_SIZE"
            ;;
        text)
            detect_text "$TARGET_DIR" "$WINDOW_SIZE"
            ;;
        all|*)
            detect_basic "$TARGET_DIR" "$WINDOW_SIZE"
            detect_text "$TARGET_DIR" "$WINDOW_SIZE"
            ;;
    esac
    
    # JSON終了
    if [ "$OUTPUT_FORMAT" = "json" ]; then
        echo "  ]"
        echo "}"
    fi
    
    echo -e "\n${GREEN}✓ 重複検出完了${RESET}" >&2
}

main "$@"
