#!/usr/bin/env bash

# ======================================
# console-check - デバッグコード検出ツール
# ======================================
# 本番環境へのデバッグコード混入を防止
# console.log, debugger等を検出してレポート

# Bash 4.0+ が必要（連想配列のため）
if [ "${BASH_VERSINFO[0]}" -lt 4 ]; then
    echo "Error: Bash 4.0 or higher is required" >&2
    echo "Current version: $BASH_VERSION" >&2
    echo "On macOS, install with: brew install bash" >&2
    exit 1
fi

set -uo pipefail

# スクリプトのディレクトリを取得
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# 共通ライブラリ読み込み
if [ -f "$SCRIPT_DIR/../lib/common.sh" ]; then
    source "$SCRIPT_DIR/../lib/common.sh"
else
    echo "Error: common.sh not found" >&2
    exit 1
fi

# バージョン
VERSION="1.0.0"

# デフォルト設定
OUTPUT_FORMAT="console"
SEVERITY_FILTER="all"
EXCLUDE_DIRS=("node_modules" "dist" "build" ".git" "coverage")
SHOW_CONTEXT=false
VERBOSE=false
TARGET_DIR=""

# 検出パターン定義
declare -A PATTERNS
PATTERNS["console.log"]="CRITICAL"
PATTERNS["console.debug"]="CRITICAL"
PATTERNS["console.warn"]="WARNING"
PATTERNS["console.error"]="WARNING"
PATTERNS["console.info"]="INFO"
PATTERNS["console.trace"]="WARNING"
PATTERNS["alert("]="CRITICAL"
PATTERNS["debugger"]="CRITICAL"

# 検出結果を保存
declare -a RESULTS=()
declare -A SEVERITY_COUNTS
SEVERITY_COUNTS["CRITICAL"]=0
SEVERITY_COUNTS["WARNING"]=0
SEVERITY_COUNTS["INFO"]=0
declare -A TYPE_COUNTS

# ヘルプ表示
show_help() {
    cat << EOF
${BLUE}console-check v${VERSION}${NC}
デバッグコード検出ツール - 本番環境への混入を防止

${BLUE}使用方法:${NC}
  console-check [options] <target-directory>

${BLUE}オプション:${NC}
  ${GREEN}-h, --help${NC}              このヘルプを表示
  ${GREEN}-v, --version${NC}           バージョン情報を表示
  ${GREEN}-o, --output${NC} FORMAT     出力形式 (console|json|csv) [default: console]
  ${GREEN}-s, --severity${NC} LEVEL    重要度フィルタ (critical|warning|info|all) [default: all]
  ${GREEN}-c, --context${NC}           コード前後のコンテキストを表示
  ${GREEN}-e, --exclude${NC} DIR       除外ディレクトリを追加 (複数指定可)
  ${GREEN}--verbose${NC}               詳細ログを表示
  ${GREEN}--threshold${NC} N           検出数がN個以上の場合に終了コード1を返す

${BLUE}検出対象:${NC}
  ${RED}CRITICAL${NC}  console.log, console.debug, alert(), debugger
  ${YELLOW}WARNING${NC}   console.warn, console.error, console.trace
  ${CYAN}INFO${NC}      console.info

${BLUE}例:${NC}
  # 基本的な使用
  console-check ./src

  # JSON形式で出力
  console-check --output json ./src > report.json

  # CRITICAL のみ検出
  console-check --severity critical ./src

  # コンテキスト付きで表示
  console-check --context ./src

  # CI/CDで使用（10個以上でエラー）
  console-check --threshold 10 --output json ./src

${BLUE}除外ディレクトリ（デフォルト）:${NC}
  node_modules, dist, build, .git, coverage

EOF
}

# バージョン表示
show_version() {
    echo "console-check v${VERSION}"
}

# 引数パース
parse_arguments() {
    local threshold=0

    while [[ $# -gt 0 ]]; do
        case $1 in
            -h|--help)
                show_help
                exit 0
                ;;
            -v|--version)
                show_version
                exit 0
                ;;
            -o|--output)
                OUTPUT_FORMAT="$2"
                shift 2
                ;;
            -s|--severity)
                SEVERITY_FILTER="$2"
                shift 2
                ;;
            -c|--context)
                SHOW_CONTEXT=true
                shift
                ;;
            -e|--exclude)
                EXCLUDE_DIRS+=("$2")
                shift 2
                ;;
            --verbose)
                VERBOSE=true
                LOG_LEVEL=$LOG_DEBUG
                shift
                ;;
            --threshold)
                threshold="$2"
                shift 2
                ;;
            -*)
                log_error "不明なオプション: $1"
                echo "詳細は 'console-check --help' を参照してください。"
                exit 1
                ;;
            *)
                TARGET_DIR="$1"
                shift
                ;;
        esac
    done

    # 対象ディレクトリの検証
    if [ -z "$TARGET_DIR" ]; then
        log_error "対象ディレクトリが指定されていません"
        echo "使用方法: console-check [options] <target-directory>"
        exit 1
    fi

    if [ ! -d "$TARGET_DIR" ]; then
        log_error "ディレクトリが存在しません: $TARGET_DIR"
        exit 1
    fi

    # 出力形式の検証
    case "$OUTPUT_FORMAT" in
        console|json|csv)
            ;;
        *)
            log_error "無効な出力形式: $OUTPUT_FORMAT"
            echo "有効な形式: console, json, csv"
            exit 1
            ;;
    esac

    # 重要度フィルタの検証
    case "$SEVERITY_FILTER" in
        all|critical|warning|info)
            SEVERITY_FILTER=$(echo "$SEVERITY_FILTER" | tr '[:lower:]' '[:upper:]')
            if [ "$SEVERITY_FILTER" = "ALL" ]; then
                SEVERITY_FILTER=""
            fi
            ;;
        *)
            log_error "無効な重要度: $SEVERITY_FILTER"
            echo "有効な重要度: all, critical, warning, info"
            exit 1
            ;;
    esac

    export THRESHOLD=$threshold
}

# 除外パターン生成
generate_exclude_pattern() {
    local exclude_pattern=""
    for dir in "${EXCLUDE_DIRS[@]}"; do
        if [ -n "$exclude_pattern" ]; then
            exclude_pattern="$exclude_pattern|$dir"
        else
            exclude_pattern="$dir"
        fi
    done
    echo "$exclude_pattern"
}

# ファイルスキャン
scan_files() {
    local target="$1"
    local exclude_pattern=$(generate_exclude_pattern)

    log_info "スキャン開始: $target"

    if [ "$VERBOSE" = true ]; then
        log_debug "除外ディレクトリ: ${EXCLUDE_DIRS[*]}"
    fi

    # JavaScriptファイルを検索
    local file_list
    if [ -n "$exclude_pattern" ]; then
        file_list=$(find "$target" -type f \( -name "*.js" -o -name "*.jsx" -o -name "*.ts" -o -name "*.tsx" \) \
            | grep -vE "($exclude_pattern)" || true)
    else
        file_list=$(find "$target" -type f \( -name "*.js" -o -name "*.jsx" -o -name "*.ts" -o -name "*.tsx" \) || true)
    fi

    local total_files=$(echo "$file_list" | wc -l | tr -d ' ')
    log_info "スキャン対象: ${total_files}ファイル"

    local current=0

    # 各ファイルをスキャン
    echo "DEBUG: Starting file loop" >&2
    while IFS= read -r file; do
        echo "DEBUG: Read file: '$file'" >&2
        [ -z "$file" ] && continue
        current=$((current + 1))
        echo "DEBUG: Processing file $current: $file" >&2

        if [ "$VERBOSE" = true ]; then
            show_progress $current $total_files "$(basename "$file")"
        fi

        scan_file "$file"
        echo "DEBUG: Finished scanning $file" >&2
    done <<< "$file_list"
    echo "DEBUG: File loop completed" >&2

    if [ "$VERBOSE" = true ] && [ $current -gt 0 ]; then
        echo ""
    fi
}

# 単一ファイルをスキャン
scan_file() {
    local file="$1"
    echo "DEBUG: Scanning file: $file" >&2

    # 各パターンを検索
    for pattern in "${!PATTERNS[@]}"; do
        echo "DEBUG: Checking pattern: $pattern" >&2
        local severity="${PATTERNS[$pattern]}"

        # 重要度フィルタリング
        if [ -n "$SEVERITY_FILTER" ] && [ "$severity" != "$SEVERITY_FILTER" ]; then
            continue
        fi

        # パターン検索（行番号付き、コメント除外）
        local matches=$(grep -n "$pattern" "$file" 2>/dev/null | grep -v "^[[:space:]]*//" | grep -v "^[[:space:]]*\*" || true)

        if [ -n "$matches" ]; then
            while IFS= read -r match; do
                local line_num=$(echo "$match" | cut -d: -f1)
                local line_content=$(echo "$match" | cut -d: -f2-)

                # 文字列内のパターンを除外（簡易チェック）
                if echo "$line_content" | grep -q "['\"].*$pattern.*['\"]"; then
                    continue
                fi

                # 検出結果を記録
                record_detection "$file" "$line_num" "$pattern" "$severity" "$line_content"
            done <<< "$matches"
        fi
    done
}

# 検出結果を記録
record_detection() {
    local file="$1"
    local line_num="$2"
    local pattern="$3"
    local severity="$4"
    local line_content="$5"

    # 結果を配列に追加
    RESULTS+=("$severity|$pattern|$file|$line_num|$line_content")

    # カウンタ更新
    ((SEVERITY_COUNTS[$severity]++)) || true

    # TYPE_COUNTSの初期化チェック
    if [ -z "${TYPE_COUNTS[$pattern]+x}" ]; then
        TYPE_COUNTS[$pattern]=0
    fi
    ((TYPE_COUNTS[$pattern]++)) || true
}

# Console形式で出力
output_console() {
    if [ ${#RESULTS[@]} -eq 0 ]; then
        log_success "デバッグコードは検出されませんでした"
        return
    fi

    echo ""
    echo -e "${PURPLE}=== デバッグコード検出レポート ===${NC}"
    echo ""

    # 重要度別に出力
    for severity in "CRITICAL" "WARNING" "INFO"; do
        local count=${SEVERITY_COUNTS[$severity]}
        if [ $count -eq 0 ]; then
            continue
        fi

        case $severity in
            CRITICAL)
                echo -e "${RED}▼ ${severity} (${count}件)${NC}"
                ;;
            WARNING)
                echo -e "${YELLOW}▼ ${severity} (${count}件)${NC}"
                ;;
            INFO)
                echo -e "${CYAN}▼ ${severity} (${count}件)${NC}"
                ;;
        esac

        for result in "${RESULTS[@]}"; do
            IFS='|' read -r sev pattern file line_num line_content <<< "$result"

            if [ "$sev" = "$severity" ]; then
                echo -e "  ${BLUE}[$pattern]${NC} $file:${GREEN}$line_num${NC}"
                if [ "$SHOW_CONTEXT" = true ]; then
                    echo -e "    ${line_content}"
                fi
            fi
        done
        echo ""
    done

    # 統計情報
    echo -e "${PURPLE}=== 統計情報 ===${NC}"
    echo -e "  総検出数: ${RED}${#RESULTS[@]}${NC}件"
    echo ""
    echo "  重要度別:"
    for severity in "CRITICAL" "WARNING" "INFO"; do
        local count=${SEVERITY_COUNTS[$severity]}
        if [ $count -gt 0 ]; then
            echo "    $severity: $count件"
        fi
    done
    echo ""
    echo "  タイプ別:"
    for pattern in "${!TYPE_COUNTS[@]}"; do
        echo "    $pattern: ${TYPE_COUNTS[$pattern]}件"
    done
    echo ""
}

# JSON形式で出力
output_json() {
    echo "{"
    echo "  \"summary\": {"
    echo "    \"total\": ${#RESULTS[@]},"
    echo "    \"critical\": ${SEVERITY_COUNTS[CRITICAL]},"
    echo "    \"warning\": ${SEVERITY_COUNTS[WARNING]},"
    echo "    \"info\": ${SEVERITY_COUNTS[INFO]}"
    echo "  },"
    echo "  \"detections\": ["

    local first=true
    for result in "${RESULTS[@]}"; do
        IFS='|' read -r severity pattern file line_num line_content <<< "$result"

        if [ "$first" = true ]; then
            first=false
        else
            echo ","
        fi

        # JSON エスケープ
        line_content=$(echo "$line_content" | sed 's/"/\\"/g' | sed 's/\\/\\\\/g')

        echo -n "    {"
        echo -n "\"severity\": \"$severity\", "
        echo -n "\"type\": \"$pattern\", "
        echo -n "\"file\": \"$file\", "
        echo -n "\"line\": $line_num, "
        echo -n "\"content\": \"$line_content\""
        echo -n "}"
    done

    echo ""
    echo "  ]"
    echo "}"
}

# CSV形式で出力
output_csv() {
    echo "severity,type,file,line,content"

    for result in "${RESULTS[@]}"; do
        IFS='|' read -r severity pattern file line_num line_content <<< "$result"

        # CSVエスケープ
        line_content=$(echo "$line_content" | sed 's/"/""/g')

        echo "\"$severity\",\"$pattern\",\"$file\",$line_num,\"$line_content\""
    done
}

# 結果出力
output_results() {
    case "$OUTPUT_FORMAT" in
        console)
            output_console
            ;;
        json)
            output_json
            ;;
        csv)
            output_csv
            ;;
    esac
}

# 閾値チェック
check_threshold() {
    if [ -n "${THRESHOLD:-}" ] && [ "$THRESHOLD" -gt 0 ]; then
        if [ ${#RESULTS[@]} -ge $THRESHOLD ]; then
            log_error "検出数が閾値($THRESHOLD)以上です: ${#RESULTS[@]}件"
            return 1
        fi
    fi
    return 0
}

# メイン処理
main() {
    parse_arguments "$@"

    log_info "console-check v${VERSION} を実行中..."

    scan_files "$TARGET_DIR"

    output_results

    if ! check_threshold; then
        exit 1
    fi

    if [ ${#RESULTS[@]} -eq 0 ]; then
        exit 0
    else
        # 検出があった場合は終了コード2
        exit 2
    fi
}

# スクリプト実行
main "$@"
