  "detection_targets": {
    "camelCase_violations": {
      "patterns": [
        "snake_case in variables",
        "PascalCase in variables",
        "all lowercase without separation",
        "uppercase start in variables"
      ],
      "expected_count": 15
    },
    "PascalCase_violations": {
      "patterns": [
        "camelCase in class names",
        "snake_case in class names",
        "all lowercase class names",
        "all uppercase class names",
        "underscore in class names"
      ],
      "expected_count": 10
    },
    "constant_violations": {
      "patterns": [
        "camelCase in const declarations",
        "PascalCase in const declarations",
        "lowercase snake_case in const"
      ],
      "expected_count": 10
    },
    "function_violations": {
      "patterns": [
        "snake_case in function names",
        "PascalCase in function names",
        "all lowercase without separation"
      ],
      "expected_count": 8
    },
    "length_violations": {
      "patterns": [
        "single character names",
        "names exceeding 50 characters",
        "unclear abbreviations"
      ],
      "expected_count": 7
    }
  },
  "accuracy_targets": {
    "minimum_detection_rate": 0.85,
