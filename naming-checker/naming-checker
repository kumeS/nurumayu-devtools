#!/usr/bin/env bash

# ======================================
# naming-checker - 命名規則チェッカー
# ======================================
# JavaScript/TypeScriptの変数・関数・クラス名の命名規則を検証

if [ "${BASH_VERSINFO[0]}" -lt 4 ]; then
    echo "Error: Bash 4.0 or higher is required" >&2
    exit 1
fi

set -o pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# 共通ライブラリ読み込み
if [ -f "$SCRIPT_DIR/../lib/common.sh" ]; then
    source "$SCRIPT_DIR/../lib/common.sh"
else
    echo "Error: common.sh not found" >&2
    exit 1
fi

# 追加のカラー定義
BOLD='\033[1m'
RESET='\033[0m'

VERSION="1.0.0"

# デフォルト設定
OUTPUT_FORMAT="console"
TARGET_DIR=""
SHOW_STATS=false
ALLOW_SNAKE=false
MIN_LENGTH=2
MAX_LENGTH=50

# 違反カウンター
declare -A VIOLATIONS
VIOLATIONS["camelCase"]=0
VIOLATIONS["PascalCase"]=0
VIOLATIONS["CONSTANT"]=0
VIOLATIONS["snake_case"]=0
VIOLATIONS["length"]=0

TOTAL_FILES=0
TOTAL_VIOLATIONS=0

# JSON出力用配列
declare -a JSON_OUTPUT

# ======================================
# ヘルプ表示
# ======================================
show_help() {
    cat << EOF
${BOLD}${CYAN}naming-checker${RESET} - JavaScript/TypeScript 命名規則チェッカー v${VERSION}

${BOLD}使用方法:${RESET}
    naming-checker [OPTIONS] <target-directory>

${BOLD}オプション:${RESET}
    ${GREEN}-h, --help${RESET}                このヘルプを表示
    ${GREEN}-o, --output <format>${RESET}     出力形式 (console/json/csv)
    ${GREEN}--stats${RESET}                   統計情報を表示
    ${GREEN}--allow-snake${RESET}             スネークケースを許可
    ${GREEN}--min-length <n>${RESET}          最小変数名長 (デフォルト: 2)
    ${GREEN}--max-length <n>${RESET}          最大変数名長 (デフォルト: 50)

${BOLD}検出パターン:${RESET}
    ${RED}✗${RESET} 変数がsnake_caseである
    ${RED}✗${RESET} 関数がsnake_caseである  
    ${RED}✗${RESET} クラスがcamelCaseである
    ${RED}✗${RESET} 定数がcamelCaseである

${BOLD}使用例:${RESET}
    naming-checker ./src
    naming-checker --output json ./src > report.json
    naming-checker --stats ./project

EOF
}

# ======================================
# チェック関数
# ======================================
is_camel_case() {
    [[ "$1" =~ ^[a-z][a-zA-Z0-9]*$ ]]
}

is_pascal_case() {
    [[ "$1" =~ ^[A-Z][a-zA-Z0-9]*$ ]]
}

is_upper_snake() {
    [[ "$1" =~ ^[A-Z][A-Z0-9_]*$ ]]
}

has_snake() {
    [[ "$1" =~ _ ]]
}

# ======================================
# ファイル解析
# ======================================
analyze_file() {
    local file="$1"
    local line_num=0
    
    
    while IFS= read -r line || [ -n "$line" ]; do
        line_num=$((line_num + 1))
        
        
        # コメントスキップ
        [[ "$line" =~ ^[[:space:]]*// ]] && continue
        [[ "$line" =~ ^[[:space:]]*\* ]] && continue
        
        # 変数宣言
        if [[ "$line" =~ (let|var)[[:space:]]+([a-zA-Z_][a-zA-Z0-9_]*) ]]; then
            local var_name="${BASH_REMATCH[2]}"
            
            if has_snake "$var_name" && [ "$ALLOW_SNAKE" = false ]; then
                report_violation "$file" "$line_num" "SNAKE_CASE" "Variable '$var_name' uses snake_case"
                ((VIOLATIONS["snake_case"]++))
                ((TOTAL_VIOLATIONS++))
            elif ! is_camel_case "$var_name" && ! has_snake "$var_name"; then
                if is_pascal_case "$var_name"; then
                    report_violation "$file" "$line_num" "CAMEL_CASE" "Variable '$var_name' should start with lowercase"
                    ((VIOLATIONS["camelCase"]++))
                    ((TOTAL_VIOLATIONS++))
                fi
            fi
            
            # 長さチェック
            local len=${#var_name}
            if [ "$len" -lt "$MIN_LENGTH" ]; then
                report_violation "$file" "$line_num" "LENGTH" "Variable '$var_name' is too short"
                ((VIOLATIONS["length"]++))
                ((TOTAL_VIOLATIONS++))
            elif [ "$len" -gt "$MAX_LENGTH" ]; then
                report_violation "$file" "$line_num" "LENGTH" "Variable '$var_name' is too long"
                ((VIOLATIONS["length"]++))
                ((TOTAL_VIOLATIONS++))
            fi
        fi
        
        # 定数宣言
        if [[ "$line" =~ const[[:space:]]+([a-zA-Z_][a-zA-Z0-9_]*) ]]; then
            local const_name="${BASH_REMATCH[1]}"
            
            if ! is_upper_snake "$const_name"; then
                report_violation "$file" "$line_num" "CONSTANT" "Constant '$const_name' should be UPPER_SNAKE_CASE"
                ((VIOLATIONS["CONSTANT"]++))
                ((TOTAL_VIOLATIONS++))
            fi
        fi
        
        # 関数宣言
        if [[ "$line" =~ function[[:space:]]+([a-zA-Z_][a-zA-Z0-9_]*) ]]; then
            local func_name="${BASH_REMATCH[1]}"
            
            if has_snake "$func_name" && [ "$ALLOW_SNAKE" = false ]; then
                report_violation "$file" "$line_num" "SNAKE_CASE" "Function '$func_name' uses snake_case"
                ((VIOLATIONS["snake_case"]++))
                ((TOTAL_VIOLATIONS++))
            fi
        fi
        
        # クラス宣言
        if [[ "$line" =~ class[[:space:]]+([a-zA-Z_][a-zA-Z0-9_]*) ]]; then
            local class_name="${BASH_REMATCH[1]}"
            
            if ! is_pascal_case "$class_name"; then
                report_violation "$file" "$line_num" "PASCAL_CASE" "Class '$class_name' should be PascalCase"
                ((VIOLATIONS["PascalCase"]++))
                ((TOTAL_VIOLATIONS++))
            fi
        fi
        
    done < "$file"
}

# ======================================
# 違反報告
# ======================================
report_violation() {
    local file="$1"
    local line="$2"
    local type="$3"
    local message="$4"
    
    echo "[DEBUG-VIOLATION] Called: $type at $file:$line" >&2
    
    case "$OUTPUT_FORMAT" in
        json)
            JSON_OUTPUT+=("{\"file\":\"$file\",\"line\":$line,\"type\":\"$type\",\"message\":\"$message\"}")
            ;;
        csv)
            echo "$file,$line,$type,\"$message\""
            ;;
        console|*)
            echo -e "${RED}✗ [$type]${RESET} $file:${GREEN}$line${RESET}"
            echo -e "  $message"
            ;;
    esac
    
    echo "[DEBUG-VIOLATION] Finished outputting" >&2
}

# ======================================
# ディレクトリスキャン
# ======================================
scan_directory() {
    local target="$1"
    
    
    if [ ! -d "$target" ]; then
        log_error "Directory not found: $target"
        exit 1
    fi
    
    log_info "Scanning directory: $target"
    echo ""
    
    # JSON/CSVヘッダー
    if [ "$OUTPUT_FORMAT" = "json" ]; then
        echo "{"
        echo "  \"tool\": \"naming-checker\","
        echo "  \"version\": \"$VERSION\","
        echo "  \"violations\": ["
    elif [ "$OUTPUT_FORMAT" = "csv" ]; then
        echo "file,line,type,message"
    fi
    
    
    # ファイルを検索して解析
    local files=()
    while IFS= read -r file; do
        files+=("$file")
    done < <(find "$target" -type f \( -name "*.js" -o -name "*.jsx" -o -name "*.ts" -o -name "*.tsx" \) \
        ! -path "*/node_modules/*" ! -path "*/dist/*" ! -path "*/build/*" ! -path "*/.git/*")
    
    for file in "${files[@]}"; do
        TOTAL_FILES=$((TOTAL_FILES + 1))
        echo "[DEBUG-SCAN] Processing file #$TOTAL_FILES: $file" >&2
        analyze_file "$file"
        echo "[DEBUG-SCAN] Finished file #$TOTAL_FILES" >&2
    done
    
    echo "[DEBUG-SCAN] Loop finished. Total files: $TOTAL_FILES, Total violations: $TOTAL_VIOLATIONS" >&2
    
    
    # JSON出力終了
    if [ "$OUTPUT_FORMAT" = "json" ]; then
        local first=true
        for item in "${JSON_OUTPUT[@]}"; do
            if [ "$first" = true ]; then
                first=false
                echo "    $item"
            else
                echo "    ,$item"
            fi
        done
        echo "  ],"
        echo "  \"summary\": {"
        echo "    \"total_files\": $TOTAL_FILES,"
        echo "    \"total_violations\": $TOTAL_VIOLATIONS"
        echo "  }"
        echo "}"
    fi
}

# ======================================
# 統計表示
# ======================================
show_statistics() {
    echo ""
    echo -e "${BOLD}${CYAN}=== 命名規則チェック統計 ===${RESET}"
    echo ""
    echo -e "  ${BOLD}スキャン対象:${RESET} $TOTAL_FILES ファイル"
    echo -e "  ${BOLD}総違反数:${RESET} $TOTAL_VIOLATIONS 件"
    echo ""
    echo -e "${BOLD}違反内訳:${RESET}"
    echo -e "  ${RED}✗${RESET} camelCase違反:      ${VIOLATIONS["camelCase"]} 件"
    echo -e "  ${RED}✗${RESET} PascalCase違反:     ${VIOLATIONS["PascalCase"]} 件"
    echo -e "  ${YELLOW}⚠${RESET} 定数命名違反:       ${VIOLATIONS["CONSTANT"]} 件"
    echo -e "  ${YELLOW}⚠${RESET} snake_case使用:    ${VIOLATIONS["snake_case"]} 件"
    echo -e "  ${BLUE}ℹ${RESET} 長さ違反:          ${VIOLATIONS["length"]} 件"
    echo ""
    
    if [ "$TOTAL_VIOLATIONS" -eq 0 ]; then
        echo -e "  ${GREEN}${BOLD}✓ 素晴らしい！ 命名規則違反はありません${RESET}"
    elif [ "$TOTAL_VIOLATIONS" -lt 10 ]; then
        echo -e "  ${GREEN}${BOLD}✓ 良好: 違反は少なめです${RESET}"
    elif [ "$TOTAL_VIOLATIONS" -lt 50 ]; then
        echo -e "  ${YELLOW}${BOLD}⚠ 注意: いくつか改善の余地があります${RESET}"
    else
        echo -e "  ${RED}${BOLD}✗ 要改善: 多くの違反が検出されました${RESET}"
    fi
    echo ""
}

# ======================================
# メイン処理
# ======================================
main() {
    if [ $# -eq 0 ]; then
        show_help
        exit 0
    fi
    
    while [ $# -gt 0 ]; do
        case "$1" in
            -h|--help)
                show_help
                exit 0
                ;;
            -o|--output)
                OUTPUT_FORMAT="$2"
                shift 2
                ;;
            --stats)
                SHOW_STATS=true
                shift
                ;;
            --allow-snake)
                ALLOW_SNAKE=true
                shift
                ;;
            --min-length)
                MIN_LENGTH="$2"
                shift 2
                ;;
            --max-length)
                MAX_LENGTH="$2"
                shift 2
                ;;
            -*)
                log_error "Unknown option: $1"
                exit 1
                ;;
            *)
                TARGET_DIR="$1"
                shift
                ;;
        esac
    done
    
    if [ -z "$TARGET_DIR" ]; then
        log_error "Target directory is required"
        exit 1
    fi
    
    scan_directory "$TARGET_DIR"
    
    if [ "$SHOW_STATS" = true ] && [ "$OUTPUT_FORMAT" = "console" ]; then
        show_statistics
    fi
    
    echo "[DEBUG] Final TOTAL_VIOLATIONS: $TOTAL_VIOLATIONS" >&2
    
    if [ "$TOTAL_VIOLATIONS" -gt 0 ]; then
        exit 1
    else
        if [ "$OUTPUT_FORMAT" = "console" ]; then
            echo ""
            log_success "No naming violations found!"
        fi
        exit 0
    fi
}

main "$@"
